{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "types": ["node"],
  },
  "include": ["src/**/*", "generated/**/*"]
}